# --- App ---
JWT_SECRET=                    # 32+ random chars; openssl rand -hex 32
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=           # bcrypt hash of admin password; node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ENCRYPTION_KEY=                # 32 bytes hex (64 chars); openssl rand -hex 32

# --- Database (Northflank-provided) ---
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- WAHA (your existing Northflank service) ---
WAHA_URL=https://your-waha.northflank.app
WAHA_API_KEY=
WAHA_SESSION=default           # WAHA session name (matches WAHA_SESSION in the WAHA service)

# --- Health check ---
HEALTH_CHECK_TOKEN=            # token guarding GET /api/health; openssl rand -hex 16. Point an uptime monitor at /api/health?token=... If empty, the endpoint is open.

# --- App runtime ---
PORT=3000
NODE_ENV=production
